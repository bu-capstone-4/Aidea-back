# ── MySQL ─────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=
DB_USERNAME=
DB_PASSWORD=

# ── Spring ────────────────────────────────────────────────────────────────────
# docker-compose에서 자동 주입되므로 직접 수정 불필요
DB_URL=jdbc:mysql://mysql:3306/aidea_db?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DDL_AUTO=validate
SHOW_SQL=false

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
# https://github.com/settings/developers 에서 발급
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── JWT ───────────────────────────────────────────────────────────────────────
# 256비트 이상 랜덤 문자열
JWT_SECRET=

# ── Frontend ──────────────────────────────────────────────────────────────────
# OAuth 로그인 완료 후 리다이렉트될 프론트엔드 주소
FRONTEND_URL=https://your-frontend-domain.com

# ── App ───────────────────────────────────────────────────────────────────────
# 초대 링크 만료 시간 (시간 단위, 기본 48)
APP_INVITATION_EXPIRY_HOURS=48

# ── ECR ───────────────────────────────────────────────────────────────────────
# GitHub Actions가 배포 시 자동으로 주입 (.env에 직접 설정 불필요)
ECR_IMAGE=

# smtp
# 발신자 이메일
SMTP_EMAIL=
# 발신자 어플리케이션 비밀번호
SMTP_PASSWORD=